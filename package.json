{
  "name": "aiclocker",
  "productName": "AIClocker",
  "version": "1.2.0",
  "description": "Windows tray app that tracks your AI coding tool usage — tokens, API-equivalent cost, time, and model breakdown. Supports Claude Code and Claude Co-Work with a plugin architecture for adding more tools.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test-ingest": "node src/test-ingest.js",
    "make-icon": "node scripts/make-icon.js",
    "make-cert": "node scripts/make-cert.js",
    "build:dir": "electron-builder --dir",
    "build": "electron-builder",
    "build:publish": "electron-builder --publish always",
    "sync": "node scripts/sync-public.js",
    "sync:dry": "node scripts/sync-public.js --dry"
  },
  "author": {
    "name": "Ben Kirtland",
    "email": "feedback@mousewheeldigital.com",
    "url": "https://www.mousewheeldigital.com/"
  },
  "homepage": "https://github.com/MorlachAU/aiclocker",
  "repository": {
    "type": "git",
    "url": "https://github.com/MorlachAU/aiclocker.git"
  },
  "bugs": {
    "url": "https://github.com/MorlachAU/aiclocker/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.mousewheeldigital.aiclocker",
    "productName": "AIClocker",
    "copyright": "Copyright © 2026 Ben Kirtland (MouseWheel Digital)",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "src/**/*",
      "dashboard/**/*",
      "icon.png",
      "icon.ico",
      "package.json",
      "!scripts/**/*",
      "!certs/**/*",
      "!dist/**/*",
      "!data/**/*",
      "!docs/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ]
      }
    },
    "portable": {
      "artifactName": "AIClocker-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AIClocker",
      "uninstallDisplayName": "AIClocker",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "AIClocker-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "MorlachAU",
      "repo": "aiclocker",
      "private": false,
      "releaseType": "release"
    }
  }
}
